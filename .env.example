# Anthropic API key — required for `buxter draw` and `buxter retry`.
ANTHROPIC_API_KEY=

# Absolute path to the FreeCAD headless binary. If unset, Buxter searches
# PATH for `freecadcmd` / `FreeCADCmd`.
# Ubuntu:  /usr/bin/freecadcmd
# macOS:   /Applications/FreeCAD.app/Contents/Resources/bin/freecadcmd
FREECAD_CMD=

# Default output directory for generated artifacts.
BUXTER_OUTPUT_DIR=./out

# Default Claude model alias. Accepts: "opus", "sonnet", or a full model id.
BUXTER_MODEL=opus

# Per-run timeout for freecadcmd, in seconds.
BUXTER_RUN_TIMEOUT=120
