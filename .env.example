# Anthropic API key — required for `buxter draw` and `buxter retry`.
ANTHROPIC_API_KEY=

# Modeling backend: freecad (default) or fusion.
BUXTER_BACKEND=freecad

# Absolute path to the FreeCAD headless binary. If unset, Buxter searches
# PATH for `freecadcmd` / `FreeCADCmd`.
# Ubuntu:  /usr/bin/freecadcmd
# macOS:   /Applications/FreeCAD.app/Contents/Resources/bin/freecadcmd
FREECAD_CMD=

# Absolute path to the Autodesk Fusion 360 binary. Required only when
# BUXTER_BACKEND=fusion AND FUSION_EXEC_MODE=subprocess.
# macOS:   /Applications/Autodesk Fusion 360.app/Contents/MacOS/Autodesk Fusion 360
# Windows: C:\Users\Public\Autodesk\webdeploy\production\Fusion360.exe
FUSION_CMD=

# How the Fusion backend executes the generated script.
#   dryrun     — write the script to out/_gen_fusion.py and stop (default).
#                Run it manually in Fusion (Utilities → Add-Ins → Scripts) or
#                via the Claude Fusion 360 MCP connector.
#   subprocess — invoke FUSION_CMD with -ExecuteScript=. Workstation only,
#                requires a foreground GUI session.
FUSION_EXEC_MODE=dryrun

# Also export a native .f3d archive when the Fusion backend runs.
FUSION_EMIT_F3D=false

# Default output directory for generated artifacts.
BUXTER_OUTPUT_DIR=./out

# Default Claude model alias. Accepts: "opus", "sonnet", or a full model id.
BUXTER_MODEL=opus

# Per-run timeout for the modeling backend, in seconds.
BUXTER_RUN_TIMEOUT=120
